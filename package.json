{
  "name": "@etchteam/next-pagination",
  "version": "3.5.5",
  "description": "Pagination component for Next.js apps",
  "author": "etchteam",
  "license": "MIT",
  "repository": "etchteam/next-pagination",
  "main": "dist/index.js",
  "module": "dist/index.modern.js",
  "source": "src/index.tsx",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.modern.js",
      "require": "./dist/index.js"
    },
    "./app": {
      "types": "./dist/app.d.ts",
      "import": "./dist/app.modern.js",
      "require": "./dist/app.js"
    },
    "./pages": {
      "types": "./dist/pages.d.ts",
      "import": "./dist/pages.modern.js",
      "require": "./dist/pages.js"
    },
    "./dist/index.css": "./dist/index.css",
    "./package.json": "./package.json"
  },
  "engines": {
    "node": "^20 || ^22 || ^24"
  },
  "scripts": {
    "build": "rimraf dist && microbundle-crl --no-compress --format modern,cjs -i src/index.tsx -i src/app.tsx -i src/pages.tsx && node scripts/postbuild.js",
    "start": "microbundle-crl watch --no-compress --format modern,cjs -i src/index.tsx -i src/app.tsx -i src/pages.tsx",
    "prepare": "run-s build",
    "test": "run-s test:types test:unit",
    "test:unit": "cross-env CI=1 react-scripts test --env=jsdom",
    "test:watch": "react-scripts test --env=jsdom",
    "test:types": "tsc",
    "test:e2e": "playwright test",
    "predeploy": "cd example && npm install && npm run build && touch build/.nojekyll",
    "deploy": "gh-pages -t -d example/build"
  },
  "peerDependencies": {
    "next": ">=10",
    "react": ">=16"
  },
  "dependencies": {
    "classnames": "^2.3.1",
    "lodash": "4.18.1",
    "query-string": "6.12.1"
  },
  "devDependencies": {
    "@playwright/test": "1.59.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^14.3.1",
    "@types/jest": "^27.5.0",
    "@types/lodash": "^4.14.182",
    "@types/node": "^17.0.31",
    "@types/react": "^18.0.8",
    "@typescript-eslint/eslint-plugin": "^5.22.0",
    "@typescript-eslint/parser": "^5.22.0",
    "babel-eslint": "^10.0.3",
    "cross-env": "^7.0.2",
    "eslint": "^7.1.0",
    "eslint-config-prettier": "^6.7.0",
    "eslint-plugin-import": "^2.26.0",
    "eslint-plugin-prettier": "^3.1.1",
    "eslint-plugin-react": "^7.17.0",
    "gh-pages": "^5.0.0",
    "microbundle-crl": "^0.13.8",
    "next": "^16.1.5",
    "npm-run-all": "^4.1.5",
    "prettier": "^2.0.4",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-scripts": "^5.0.1",
    "typescript": "^4.6.4"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  }
}
