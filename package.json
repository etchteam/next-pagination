{
  "name": "@etchteam/next-pagination",
  "version": "3.5.5",
  "description": "Pagination component for Next.js apps",
  "author": "etchteam",
  "license": "MIT",
  "repository": "etchteam/next-pagination",
  "main": "dist/index.js",
  "module": "dist/index.modern.js",
  "source": "src/index.tsx",
  "engines": {
    "node": "^20 || ^22 || ^24"
  },
  "scripts": {
    "build": "microbundle-crl --no-compress --format modern,cjs",
    "start": "microbundle-crl watch --no-compress --format modern,cjs",
    "prepare": "run-s build",
    "test": "run-s test:types test:unit",
    "test:unit": "jest",
    "test:watch": "jest --watch",
    "test:types": "tsc",
    "lint": "run-s lint:js lint:css",
    "lint:js": "eslint .",
    "lint:css": "stylelint \"{src,example/styles}/**/*.{css,scss}\"",
    "predeploy": "cd example && npm install && npm run build && touch build/.nojekyll",
    "deploy": "gh-pages -t -d example/build"
  },
  "peerDependencies": {
    "next": ">=10",
    "react": ">=16"
  },
  "dependencies": {
    "classnames": "^2.3.1",
    "lodash": "4.18.1",
    "prop-types": "^15.8.1",
    "query-string": "6.12.1"
  },
  "devDependencies": {
    "@eslint/compat": "^2.0.5",
    "@etchteam/eslint-config": "^3.3.3",
    "@etchteam/stylelint-config": "^1.7.2",
    "@next/eslint-plugin-next": "^16.2.4",
    "@types/jest": "^29.5.12",
    "@types/lodash": "^4.14.182",
    "@types/node": "^17.0.31",
    "@types/react": "^18.0.8",
    "eslint": "^9.39.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-storybook": "^10.3.5",
    "gh-pages": "^5.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "microbundle-crl": "^0.13.8",
    "next": "^16.1.5",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.8.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "stylelint": "^16.26.1",
    "ts-jest": "~29.1.2",
    "typescript": "^4.6.4"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  }
}
